# Copy to .env.local for local dev (jamais commit)
# En prod, définir ces variables dans Vercel → Settings → Environment Variables

# URL canonique (utilisée par sitemap, robots, OG tags)
NEXT_PUBLIC_SITE_URL=https://ousurfer.fr

# Client AdSense — à renseigner après validation
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Blocs publicitaires AdSense — à créer dans AdSense > Annonces > Par bloc d'annonces
# NEXT_PUBLIC_ADSENSE_SLOT_IN_FEED=1234567890
# NEXT_PUBLIC_ADSENSE_SLOT_SPOT_DETAIL=1234567890
