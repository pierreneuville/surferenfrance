# Copy to .env.local for local dev (jamais commit)
# En prod, définir ces variables dans Vercel → Settings → Environment Variables

# === SEO / canonicals ===
NEXT_PUBLIC_SITE_URL=https://yosurf.fr

# === AdSense (revenu pub principal) ===
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_SLOT_IN_FEED=1234567890
# NEXT_PUBLIC_ADSENSE_SLOT_SPOT_DETAIL=1234567890

# === Analytics (mesure d'audience) ===
# Plausible (recommandé EU, cookieless) — créer compte plausible.io
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yosurf.fr
# Google Analytics 4 (gratuit, gated par consent en EU)
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# === Email capture (newsletter + Yosurf+ waitlist) ===
# Endpoint où sont POST les leads. Buttondown / Brevo / Resend / API custom
# NEXT_PUBLIC_NEWSLETTER_ENDPOINT=https://api.buttondown.email/v1/subscribers
